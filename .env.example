# Supabase — copy to .env and fill in with your project's values.
# The EXPO_PUBLIC_ prefix makes them available in the app via process.env.
# The anon key is safe to ship in the client; all data is protected by RLS
# and the zero-knowledge encryption (the server only ever sees ciphertext).
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
